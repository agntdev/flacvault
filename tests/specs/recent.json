[
  {
    "name": "/recent shows empty state when no tracks exist",
    "steps": [
      {
        "send": { "text": "/recent" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No tracks submitted yet. Be the first to upload one!"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Recent button opens recent tracks",
    "steps": [
      {
        "send": { "callback": "recent:show" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No tracks submitted yet. Be the first to upload one!"
            }
          }
        ]
      }
    ]
  }
]
