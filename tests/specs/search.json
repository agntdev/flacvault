[
  {
    "name": "/search shows prompt when no query given",
    "steps": [
      {
        "send": { "text": "/search" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "What are you looking for?\n\nSearch by title, artist, or album."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Search button opens search prompt",
    "steps": [
      {
        "send": { "callback": "search:start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "What are you looking for?\n\nSearch by title, artist, or album."
            }
          }
        ]
      }
    ]
  }
]
